# App mode: development or production
APP_ENV=production

# Backend auth (optional)
API_KEY=replace-with-strong-random-key

# Database (PostgreSQL for production)
DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>:5432/<db_name>?sslmode=require

# Backend CORS (comma-separated)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://predictive-maintenance-api.vercel.app

# Optional explicit paths
# SQLITE_DB_PATH=database/predictive_maintenance.db
# MODEL_PATH=/app/ml/model.pkl
# LOG_LEVEL=INFO
