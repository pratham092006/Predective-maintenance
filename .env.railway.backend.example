APP_ENV=production
# Optional: set API_KEY only if you want protected /predict and /history
# API_KEY=replace-with-strong-random-key
DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>:5432/<db_name>?sslmode=require
# Include all frontend origins that call this backend (Vercel + local)
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:8000,http://127.0.0.1:8000
MODEL_PATH=/app/ml/model.pkl
LOG_LEVEL=INFO
